// ============================================================
// AssetFlow — Enterprise Asset & Resource Management System
// Prisma Schema — PostgreSQL
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  ADMIN
  ASSET_MANAGER
  DEPARTMENT_HEAD
  EMPLOYEE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  POOR
  DAMAGED
}

enum AllocationStatus {
  ACTIVE
  RETURNED
  OVERDUE
  TRANSFERRED
}

enum TransferStatus {
  REQUESTED
  DEPT_HEAD_APPROVED
  MANAGER_APPROVED
  COMPLETED
  REJECTED
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
  REJECTED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AuditStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum AuditEntryStatus {
  PENDING
  VERIFIED
  DISCREPANCY
  MISSING
}

// ============================================================
// MODELS
// ============================================================

/// Organization users with role-based access control
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  role         Role     @default(EMPLOYEE)
  departmentId String?  @map("department_id")
  phone        String?
  avatar       String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  department          Department?          @relation(fields: [departmentId], references: [id])
  allocations         Allocation[]         @relation("AllocatedTo")
  allocationsCreated  Allocation[]         @relation("AllocatedBy")
  transferRequests    TransferRequest[]
  bookings            Booking[]
  maintenanceRequests MaintenanceRequest[]
  auditEntries        AuditEntry[]
  notifications       Notification[]
  activityLogs        ActivityLog[]

  @@index([departmentId])
  @@index([role])
  @@index([isActive])
  @@map("users")
}

/// Organizational departments
model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  code        String   @unique
  description String?
  headId      String?  @unique @map("head_id")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  members            User[]
  assets             Asset[]
  transfersFrom      TransferRequest[] @relation("TransferFrom")
  transfersTo        TransferRequest[] @relation("TransferTo")

  @@map("departments")
}

/// Asset classification categories
model AssetCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  code        String   @unique
  description String?
  isBookable  Boolean  @default(false) @map("is_bookable")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  assets Asset[]

  @@map("asset_categories")
}

/// Physical or virtual assets tracked by the organization
model Asset {
  id             String         @id @default(uuid())
  assetTag       String         @unique @map("asset_tag")
  name           String
  description    String?
  categoryId     String         @map("category_id")
  departmentId   String?        @map("department_id")
  serialNumber   String?        @unique @map("serial_number")
  purchaseDate   DateTime?      @map("purchase_date")
  purchaseCost   Decimal?       @db.Decimal(12, 2) @map("purchase_cost")
  warrantyExpiry DateTime?      @map("warranty_expiry")
  location       String?
  imageUrl       String?        @map("image_url")
  status         AssetStatus    @default(AVAILABLE)
  condition      AssetCondition @default(NEW)
  notes          String?
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  // Relations
  category    AssetCategory        @relation(fields: [categoryId], references: [id])
  department  Department?          @relation(fields: [departmentId], references: [id])
  allocations Allocation[]
  transfers   TransferRequest[]
  bookings    Booking[]
  maintenance MaintenanceRequest[]
  auditEntries AuditEntry[]

  @@index([categoryId])
  @@index([departmentId])
  @@index([status])
  @@map("assets")
}

/// Asset allocation records — tracks who has what
model Allocation {
  id              String           @id @default(uuid())
  assetId         String           @map("asset_id")
  allocatedToId   String           @map("allocated_to_id")
  allocatedById   String           @map("allocated_by_id")
  status          AllocationStatus @default(ACTIVE)
  allocatedAt     DateTime         @default(now()) @map("allocated_at")
  expectedReturn  DateTime?        @map("expected_return")
  returnedAt      DateTime?        @map("returned_at")
  returnCondition String?          @map("return_condition")
  returnNotes     String?          @map("return_notes")
  notes           String?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  // Relations
  asset       Asset @relation(fields: [assetId], references: [id])
  allocatedTo User  @relation("AllocatedTo", fields: [allocatedToId], references: [id])
  allocatedBy User  @relation("AllocatedBy", fields: [allocatedById], references: [id])

  @@index([assetId])
  @@index([allocatedToId])
  @@index([status])
  @@map("allocations")
}

/// Inter-department asset transfer requests with two-stage approval
model TransferRequest {
  id                 String         @id @default(uuid())
  assetId            String         @map("asset_id")
  requestedById      String         @map("requested_by_id")
  fromDepartmentId   String         @map("from_department_id")
  toDepartmentId     String         @map("to_department_id")
  status             TransferStatus @default(REQUESTED)
  reason             String
  deptHeadApproval   Boolean?       @map("dept_head_approval")
  deptHeadApprovedAt DateTime?      @map("dept_head_approved_at")
  managerApproval    Boolean?       @map("manager_approval")
  managerApprovedAt  DateTime?      @map("manager_approved_at")
  rejectionReason    String?        @map("rejection_reason")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  // Relations
  asset          Asset      @relation(fields: [assetId], references: [id])
  requestedBy    User       @relation(fields: [requestedById], references: [id])
  fromDepartment Department @relation("TransferFrom", fields: [fromDepartmentId], references: [id])
  toDepartment   Department @relation("TransferTo", fields: [toDepartmentId], references: [id])

  @@index([assetId])
  @@index([requestedById])
  @@index([status])
  @@map("transfer_requests")
}

/// Resource booking for shared/bookable assets
model Booking {
  id         String        @id @default(uuid())
  assetId    String        @map("asset_id")
  bookedById String        @map("booked_by_id")
  title      String
  startTime  DateTime      @map("start_time")
  endTime    DateTime      @map("end_time")
  status     BookingStatus @default(CONFIRMED)
  notes      String?
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  // Relations
  asset    Asset @relation(fields: [assetId], references: [id])
  bookedBy User  @relation(fields: [bookedById], references: [id])

  @@index([assetId, startTime, endTime])
  @@index([bookedById])
  @@map("bookings")
}

/// Maintenance request workflow tracking
model MaintenanceRequest {
  id               String            @id @default(uuid())
  assetId          String            @map("asset_id")
  raisedById       String            @map("raised_by_id")
  priority         Priority          @default(MEDIUM)
  status           MaintenanceStatus @default(PENDING)
  issueDescription String            @map("issue_description")
  resolution       String?
  technicianName   String?           @map("technician_name")
  estimatedCost    Decimal?          @db.Decimal(10, 2) @map("estimated_cost")
  actualCost       Decimal?          @db.Decimal(10, 2) @map("actual_cost")
  approvedAt       DateTime?         @map("approved_at")
  startedAt        DateTime?         @map("started_at")
  resolvedAt       DateTime?         @map("resolved_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  // Relations
  asset    Asset @relation(fields: [assetId], references: [id])
  raisedBy User  @relation(fields: [raisedById], references: [id])

  @@index([assetId])
  @@index([raisedById])
  @@index([status])
  @@map("maintenance_requests")
}

/// Periodic asset audit cycles
model AuditCycle {
  id          String      @id @default(uuid())
  title       String
  description String?
  status      AuditStatus @default(OPEN)
  startDate   DateTime    @map("start_date")
  endDate     DateTime?   @map("end_date")
  createdById String      @map("created_by_id")
  closedAt    DateTime?   @map("closed_at")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  // Relations
  entries AuditEntry[]

  @@index([status])
  @@map("audit_cycles")
}

/// Individual asset verification within an audit cycle
model AuditEntry {
  id           String           @id @default(uuid())
  auditCycleId String           @map("audit_cycle_id")
  assetId      String           @map("asset_id")
  verifiedById String?          @map("verified_by_id")
  status       AuditEntryStatus @default(PENDING)
  condition    AssetCondition?
  location     String?
  notes        String?
  verifiedAt   DateTime?        @map("verified_at")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  // Relations
  auditCycle AuditCycle @relation(fields: [auditCycleId], references: [id])
  asset      Asset      @relation(fields: [assetId], references: [id])
  verifiedBy User?      @relation(fields: [verifiedById], references: [id])

  @@unique([auditCycleId, assetId])
  @@index([auditCycleId])
  @@index([assetId])
  @@map("audit_entries")
}

/// In-app notifications delivered via Socket.io
model Notification {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  title      String
  message    String
  type       String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

/// Immutable audit trail for all system actions
model ActivityLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("activity_logs")
}
